# Leave VITE_API_BASE_URL / VITE_SOCKET_URL unset for local dev — the app
# defaults to same-origin relative URLs (proxied by Vite, see vite.config.ts),
# which also lets phones/tablets on the same Wi-Fi reach it via the dev
# machine's LAN IP without editing this file.
#
# Point these at your deployed Render backend in production, e.g.:
#   VITE_API_BASE_URL=https://your-api.onrender.com/api
#   VITE_SOCKET_URL=https://your-api.onrender.com
VITE_APP_NAME=Auction Night
