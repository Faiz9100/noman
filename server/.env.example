# Server
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed CORS/Socket.io origins. Include both your
# local dev URL and your deployed Vercel URL at once, e.g.:
#   CLIENT_URL=http://localhost:5173,https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Database — for MongoDB Atlas in production, use the SRV connection string
# from Atlas > Connect > Drivers, with your database user's credentials:
#   MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cricket-auction?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/cricket-auction

# Auth — generate a real secret for production, e.g.: openssl rand -base64 48
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=cricket_auction_token

# Uploads
MAX_UPLOAD_SIZE_MB=5

# Initial admin account — created/updated by `npm run seed`.
# There is no public registration endpoint; this is the only way to
# get the first admin into the database.
SEED_ADMIN_NAME=Match Day Admin
SEED_ADMIN_EMAIL=admin@auctionnight.com
SEED_ADMIN_PASSWORD=Admin@123
